{
  "name": "json-schema-ui",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/json-schema-ui/json-schema-ui.esm.js",
  "exports": {
    ".": {
      "import": "./dist/json-schema-ui/json-schema-ui.esm.js",
      "require": "./dist/json-schema-ui/json-schema-ui.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.43.5",
    "@stencil/vitest": "^1.13.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@vitest/browser-playwright": "^4.1.9",
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "dependencies": {
    "@json-schema-tools/dereferencer": "^1.6.3",
    "@json-schema-tools/meta-schema": "^1.8.0",
    "@json-schema-tools/reference-resolver": "^1.2.6",
    "@json-schema-tools/traverse": "^1.11.0"
  }
}
